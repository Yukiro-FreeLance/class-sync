{
  "name": "class-sync-desktop",
  "version": "1.0.0",
  "description": "Class Sync Student Monitoring System - Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prepare:laravel": "powershell -ExecutionPolicy Bypass -File scripts/prepare-laravel.ps1",
    "prepare:php": "powershell -ExecutionPolicy Bypass -File scripts/prepare-php.ps1",
    "clean:dist": "powershell -ExecutionPolicy Bypass -File scripts/clean-dist.ps1",
    "build": "npx electron-builder",
    "build:win": "npx electron-builder --win",
    "build:desktop": "npm run prepare:laravel && npm run prepare:php && npm run clean:dist && npm run build:win"
  },
  "author": "Class Sync",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.classsync.app",
    "productName": "Class Sync",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "php-resolver.js",
      "assets/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      {
        "from": "../",
        "to": "laravel",
        "filter": [
          "**/*",
          "!electron/**",
          "!node_modules/**",
          "!.git/**",
          "!.cursor/**",
          "!.env",
          "!.phpunit.result.cache",
          "!.phpunit.cache",
          "!docker/**",
          "!undefined/**",
          "!tests/**",
          "!database/database.sqlite",
          "!database/testing.sqlite",
          "!storage/app/packages/**",
          "!storage/app/private/**",
          "!storage/app/public/**",
          "!storage/logs/**",
          "!storage/framework/cache/data/**",
          "!storage/framework/sessions/**",
          "!storage/framework/views/**",
          "!storage/framework/testing/**"
        ]
      }
    ]
  }
}
